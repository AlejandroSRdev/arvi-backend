{
  "name": "arvi-backend",
  "version": "1.0.0",
  "description": "Backend Node.js for Arvi Evolution - AI assistant for personal growth and self-improvement.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --import ./03infrastructure/telemetry/telemetry.js server.js",
    "dev": "nodemon --import ./03infrastructure/telemetry/telemetry.js server.js",
    "test": "node --test tests/",
    "check:imports": "madge --extensions js .",
    "predeploy": "npm run check:imports",
    "verify": "node verify.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "arch:check": "madge --circular src/"
  },
  "keywords": [
    "arvi",
    "backend",
    "nodejs",
    "express",
    "stripe",
    "firebase",
    "openai",
    "gemini"
  ],
  "author": "Arvi Team",
  "license": "UNLICENSED",
  "dependencies": {
    "@google/generative-ai": "^0.1.3",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.0",
    "firebase-admin": "^13.6.0",
    "helmet": "^7.1.0",
    "openai": "^4.20.0",
    "stripe": "^16.6.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "madge": "^8.0.0",
    "nodemon": "^3.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
